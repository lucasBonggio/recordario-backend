# ==========================================
# RECORDARIO - Variables de Entorno
# ==========================================
# Copiar este archivo a .env y completar con valores reales
# NUNCA commitear .env a git (debe estar en .gitignore)

# ==========================================
# BASE DE DATOS
# ==========================================

# URL de conexión a PostgreSQL
# Formato: postgresql://usuario:password@host:puerto/nombre_db
SPRING.DATASOURCE.URL=postgresql://localhost:5432/recordario

# Usuario de la base de datos
SPRING.DATASOURCE.USERNAME=postgres

# Contraseña de la base de datos
SPRING.DATASOURCE.PASSWORD=tu_contraseña_aqui

# Estrategia de generación de schema
# Opciones:
# - create-drop    : Crea las tablas al iniciar, las elimina al cerrar (DESARROLLO)
# - create         : Crea las tablas al iniciar (TESTING)
# - update         : Actualiza schema existente (PRODUCCIÓN)
# - validate       : Valida sin cambios (PRODUCCIÓN con migrations)
SPRING_JPA_HIBERNATE_DDL_AUTO=create-drop

# ==========================================
# JWT (JSON Web Tokens)
# ==========================================

# Clave secreta para firmar JWT
# Debe ser una cadena larga y aleatoria (mínimo 32 caracteres)
# Ejemplo: openssl rand -base64 32
# ⚠️ CRÍTICO: Cambiar en producción
APPLICATION.SECURITY.JWT.CODIGO-SECRETO=tu_clave_secreta_larga_y_aleatoria_aqui_cambiar_en_produccion

# Tiempo de expiración del access token EN MILISEGUNDOS
# 15 minutos = 900000 ms
APPLICATION.SECURITY.JWT.TIEMPO-EXPIRACION=900000

# Tiempo de expiración del refresh token EN MILISEGUNDOS
# 7 días = 604800000 ms
APPLICATION.SECURITY.JWT.TIEMPO-EXPIRACION-REFRESCO=604800000

# ==========================================
# APLICACIÓN
# ==========================================

# Puerto en que corre Spring Boot
server.port=8080

# Perfil de Spring (development, test, production)
spring.profiles.active=development

# ==========================================
# CORS (Credenciales)
# ==========================================

# URL del frontend para CORS
# En desarrollo: http://localhost:5173
# En producción: https://recordario-frontend.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==========================================
# NOTAS IMPORTANTES
# ==========================================
# 
# 1. DESARROLLO LOCAL:
#    - Usar H2 en memoria para tests (ya configurado en application-test.properties)
#    - Usar PostgreSQL local o Docker Compose
#
# 2. PRODUCCIÓN (Render):
#    - Cambiar CODIGO-SECRETO a una clave nueva y segura
#    - Usar SPRING_JPA_HIBERNATE_DDL_AUTO=validate
#    - URL de BD apunta a PostgreSQL en Render
#
# 3. SEGURIDAD:
#    - Nunca publicar .env en GitHub
#    - Usar variables de entorno en plataformas cloud (Render, Vercel)
#    - Rotar clave JWT periódicamente
#
# 4. GENERACIÓN DE CLAVE SECRETA (Linux/Mac):
#    $ openssl rand -base64 32
